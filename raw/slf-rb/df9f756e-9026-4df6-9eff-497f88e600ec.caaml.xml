<caaml:SnowProfile xmlns:caaml="http://caaml.org/Schemas/SnowProfileIACS/v6.0.3" xmlns:gml="http://www.opengis.net/gml" xmlns:slf="http://www.slf.ch/snowprofile/1.0" gml:id="df9f756e-9026-4df6-9eff-497f88e600ec"><caaml:metaData><caaml:customData><slf:profiletext-list><slf:profiletext key="TEXT_BLOCK_DEFAULT"><slf:text>Assenza di vendo e nuvolosit&#224;. Suolo coperto da vegetazione a basso fusto. Profilo in zona rappresentativa per il problema diffuso di neve vecchia. Altezza neve leggermente sopra la media. Ben visibili i due importanti periodi di precipitazione di quest'inverno. Notevoli segni dell'azione del vento. In generale pochissima neve.  La superficie del manto nevoso &#232; in alcuni punti in fase costruttiva marcata. 
Le gite classiche sono a stento fattibili. Nessun segnale di pericolo osservato. Nessuna valanga recente. 
Nello strato tra 57 e 32 cm diversi fragili agglomerati da rigelo/caldo, non rappresentabili in un unico strato.</slf:text></slf:profiletext></slf:profiletext-list></caaml:customData></caaml:metaData><caaml:timeRef><caaml:recordTime><caaml:TimeInstant><caaml:timePosition>2024-12-31T10:25:00+01:00</caaml:timePosition></caaml:TimeInstant></caaml:recordTime><caaml:dateTimeReport>2024-12-31T13:22:12.508943+01:00</caaml:dateTimeReport><caaml:dateTimeLastEdit>2024-12-31T13:25:24.279897+01:00</caaml:dateTimeLastEdit></caaml:timeRef><caaml:srcRef/><caaml:locRef><caaml:name>Scai, Paso del Lucomagno, Blenio</caaml:name><caaml:validElevation><caaml:ElevationPosition uom="m"><caaml:position>2078</caaml:position></caaml:ElevationPosition></caaml:validElevation><caaml:validAspect><caaml:AspectPosition><caaml:position>NE</caaml:position></caaml:AspectPosition></caaml:validAspect><caaml:validSlopeAngle><caaml:SlopeAnglePosition uom="deg"><caaml:position>37</caaml:position></caaml:SlopeAnglePosition></caaml:validSlopeAngle><caaml:pointLocation><gml:Point id="pointID" srsName="urn:ogc:def:crs:OGC:1.3:CRS84" srsDimension="2"><gml:pos>8.790903 46.555887</gml:pos></gml:Point></caaml:pointLocation></caaml:locRef><caaml:snowProfileResultsOf><caaml:SnowProfileMeasurements dir="top down"><caaml:profileDepth uom="cm">100.0</caaml:profileDepth><caaml:weatherCond><caaml:airTempPres uom="degC">2.1</caaml:airTempPres></caaml:weatherCond><caaml:snowPackCond><caaml:hS><caaml:Components><caaml:height uom="cm">100.0</caaml:height></caaml:Components></caaml:hS></caaml:snowPackCond><caaml:stratProfile><caaml:Layer><caaml:depthTop uom="cm">0.0</caaml:depthTop><caaml:thickness uom="cm">10.0</caaml:thickness><caaml:wetness uom="">D</caaml:wetness><caaml:grainFormPrimary>RG</caaml:grainFormPrimary><caaml:grainSize uom="mm"><caaml:Components><caaml:avg>0.5</caaml:avg></caaml:Components></caaml:grainSize><caaml:hardness uom="">4F-1F</caaml:hardness></caaml:Layer><caaml:Layer><caaml:depthTop uom="cm">10.0</c