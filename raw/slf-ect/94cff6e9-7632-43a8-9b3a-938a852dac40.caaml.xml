<caaml:SnowProfile xmlns:caaml="http://caaml.org/Schemas/SnowProfileIACS/v6.0.3" xmlns:gml="http://www.opengis.net/gml" xmlns:slf="http://www.slf.ch/snowprofile/1.0" gml:id="94cff6e9-7632-43a8-9b3a-938a852dac40"><caaml:metaData><caaml:customData><slf:profiletext-list><slf:profiletext key="TEXT_BLOCK_DEFAULT"><slf:text>Couverture nuageuse importante. Fait la trace dans le col de Golette, neige dure suite du minage d'hier dans la mont&#233;e du col. Vent mod&#233;r&#233; du SW au col et sur les cr&#234;tes, visibilit&#233; jour blanc &#224; nul en matin&#233;e au-dessus de 2400 m.
Difficile avec cette m&#233;t&#233;o de choisir un bon endroit. Le profil repr&#233;sente bien n&#233;anmoins la situation au-dessus de 2400m, neige beaucoup travaill&#233;e par le vent, accumulations importantes. Sous 2300 la neige est de plus en plus meuble, poudreux en grande quantit&#233; jusqu'&#224; 2000 m, top conditions. Pas de signes de woum ou fissures.
Toute-fois attentions dans les pentes raides et abords des cr&#234;tes ou les d&#244;mes.</slf:text></slf:profiletext></slf:profiletext-list></caaml:customData></caaml:metaData><caaml:timeRef><caaml:recordTime><caaml:TimeInstant><caaml:timePosition>2025-01-30T12:00:00+01:00</caaml:timePosition></caaml:TimeInstant></caaml:recordTime><caaml:dateTimeReport>2025-01-30T16:11:13.769197+01:00</caaml:dateTimeReport><caaml:dateTimeLastEdit>2025-01-30T16:11:13.769197+01:00</caaml:dateTimeLastEdit></caaml:timeRef><caaml:srcRef/><caaml:locRef><caaml:name>Col de Golette /Les Petits Perrons/Salanfe</caaml:name><caaml:validElevation><caaml:ElevationPosition uom="m"><caaml:position>2521</caaml:position></caaml:ElevationPosition></caaml:validElevation><caaml:validAspect><caaml:AspectPosition><caaml:position>NW</caaml:position></caaml:AspectPosition></caaml:validAspect><caaml:validSlopeAngle><caaml:SlopeAnglePosition uom="deg"><caaml:position>34</caaml:position></caaml:SlopeAnglePosition></caaml:validSlopeAngle><caaml:pointLocation><gml:Point id="pointID" srsName="urn:ogc:def:crs:OGC:1.3:CRS84" srsDimension="2"><gml:pos>6.977091 46.129339</gml:pos></gml:Point></caaml:pointLocation></caaml:locRef><caaml:snowProfileResultsOf><caaml:SnowProfileMeasurements dir="top down"><caaml:profileDepth uom="cm">200.0</caaml:profileDepth><caaml:snowPackCond><caaml:hS><caaml:Components><caaml:height uom="cm">200.0</caaml:height></caaml:Components></caaml:hS></caaml:snowPackCond><caaml:stratProfile><caaml:Layer><caaml:depthTop uom="cm">0.0</caaml:depthTop><caaml:thickness uom="cm">2.0</caaml:thickness><caaml:wetness uom="">D</caaml:wetness><caaml:grainFormPrimary>PP</caaml:grainFormPrimary><caaml:grainFormSecondary>DF</caaml:grainFormSecondary><caaml:grainSize uom="mm"><caaml:Components><caaml:avg>1.0</caaml:avg><caaml:avgMax>3.0</caaml:avgMax></caaml:Components></caaml:grainSize><caaml:hardness uom="">F</caaml:hardness></caaml:Layer><caaml:Layer><caaml:depthTop uom="cm">2.0</caaml:depthTop><caaml:thi