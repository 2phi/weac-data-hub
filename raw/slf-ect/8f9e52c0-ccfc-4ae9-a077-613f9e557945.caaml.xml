<caaml:SnowProfile xmlns:caaml="http://caaml.org/Schemas/SnowProfileIACS/v6.0.3" xmlns:gml="http://www.opengis.net/gml" xmlns:slf="http://www.slf.ch/snowprofile/1.0" gml:id="8f9e52c0-ccfc-4ae9-a077-613f9e557945"><caaml:metaData><caaml:customData><slf:profiletext-list><slf:profiletext key="TEXT_BLOCK_DEFAULT"><slf:text>Profil an einer freien Hanglage, wo eine kleine Lawine vor unbestimmter Zeit spontan abgegangen ist. Schneeh&#246;he am Anriss war deutlich geringer, sowie st&#228;rker aufbauend umgewandelt. 
HS &#252;berdurchschnittlich.
Tragf&#228;higer B&#252;sserschnee unterhalb letztem Niederschlag. In der Schneedecke gibt es Schneerollen, die von oben gerollt sind.
Die Schichten 70-62cm und 34-15cm enthalten wechselnd unregelm&#228;ssige Krusten und kantige Kristalle, die wahrscheinlich von feuchten Schneerollen stammen.</slf:text></slf:profiletext></slf:profiletext-list></caaml:customData></caaml:metaData><caaml:timeRef><caaml:recordTime><caaml:TimeInstant><caaml:timePosition>2026-01-07T13:40:00+01:00</caaml:timePosition></caaml:TimeInstant></caaml:recordTime><caaml:dateTimeReport>2026-01-07T17:06:16.409966+01:00</caaml:dateTimeReport><caaml:dateTimeLastEdit>2026-01-07T17:32:02.628588+01:00</caaml:dateTimeLastEdit></caaml:timeRef><caaml:srcRef/><caaml:locRef><caaml:name>R&#228;tschajochweg, Madrisahorn, Klosters, GR</caaml:name><caaml:validElevation><caaml:ElevationPosition uom="m"><caaml:position>2667</caaml:position></caaml:ElevationPosition></caaml:validElevation><caaml:validAspect><caaml:AspectPosition><caaml:position>SW</caaml:position></caaml:AspectPosition></caaml:validAspect><caaml:validSlopeAngle><caaml:SlopeAnglePosition uom="deg"><caaml:position>33</caaml:position></caaml:SlopeAnglePosition></caaml:validSlopeAngle><caaml:pointLocation><gml:Point id="pointID" srsName="urn:ogc:def:crs:OGC:1.3:CRS84" srsDimension="2"><gml:pos>9.864253 46.932537</gml:pos></gml:Point></caaml:pointLocation></caaml:locRef><caaml:snowProfileResultsOf><caaml:SnowProfileMeasurements dir="top down"><caaml:profileDepth uom="cm">90.2</caaml:profileDepth><caaml:weatherCond><caaml:airTempPres uom="degC">-11.5</caaml:airTempPres></caaml:weatherCond><caaml:snowPackCond><caaml:hS><caaml:Components><caaml:height uom="cm">90.2</caaml:height></caaml:Components></caaml:hS></caaml:snowPackCond><caaml:stratProfile><caaml:Layer><caaml:depthTop uom="cm">0.0</caaml:depthTop><caaml:thickness uom="cm">0.2</caaml:thickness><caaml:wetness uom="">D</caaml:wetness><caaml:grainFormPrimary>FC</caaml:grainFormPrimary><caaml:grainFormSecondary>SH</caaml:grainFormSecondary><caaml:grainSize uom="mm"><caaml:Components><caaml:avg>0.2</caaml:avg><caaml:avgMax>0.5</caaml:av