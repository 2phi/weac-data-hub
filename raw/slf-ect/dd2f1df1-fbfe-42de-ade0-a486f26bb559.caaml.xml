<caaml:SnowProfile xmlns:caaml="http://caaml.org/Schemas/SnowProfileIACS/v6.0.3" xmlns:gml="http://www.opengis.net/gml" xmlns:slf="http://www.slf.ch/snowprofile/1.0" gml:id="dd2f1df1-fbfe-42de-ade0-a486f26bb559"><caaml:metaData><caaml:customData><slf:profiletext-list><slf:profiletext key="TEXT_BLOCK_DEFAULT"><slf:text>Schneeh&#246;he ist scheinbar &#252;berdurchschnittlich, ist aber der buckligen Alpweide mit gelegentlich Alpenrosenstauden geschuldet.

Schneeprofil durchwegs weich, sogar mit Ski nur teilweise tragf&#228;hig, meist noch mehr aufbauend umgewandelt als im Profil.

Der &#220;bergang vom Dezemberschneefall zur kantigen Basis auf H&#246;he 58 cm zeigte sich beim Wegschaufeln des ECT ohne Bruch als glatte Fl&#228;che, aber scheinbar gut verbunden.

Schneeoberfl&#228;che leichte Schmelzformen aber noch keine Kruste.</slf:text></slf:profiletext></slf:profiletext-list></caaml:customData></caaml:metaData><caaml:timeRef><caaml:recordTime><caaml:TimeInstant><caaml:timePosition>2024-12-30T11:52:00+01:00</caaml:timePosition></caaml:TimeInstant></caaml:recordTime><caaml:dateTimeReport>2024-12-30T20:41:05.619167+01:00</caaml:dateTimeReport><caaml:dateTimeLastEdit>2024-12-30T20:41:05.619167+01:00</caaml:dateTimeLastEdit></caaml:timeRef><caaml:srcRef/><caaml:locRef><caaml:name>Heinzenberg, L&#252;schsee</caaml:name><caaml:validElevation><caaml:ElevationPosition uom="m"><caaml:position>1936</caaml:position></caaml:ElevationPosition></caaml:validElevation><caaml:validAspect><caaml:AspectPosition><caaml:position>NE</caaml:position></caaml:AspectPosition></caaml:validAspect><caaml:validSlopeAngle><caaml:SlopeAnglePosition uom="deg"><caaml:position>32</caaml:position></caaml:SlopeAnglePosition></caaml:validSlopeAngle><caaml:pointLocation><gml:Point id="pointID" srsName="urn:ogc:def:crs:OGC:1.3:CRS84" srsDimension="2"><gml:pos>9.351847 46.6921</gml:pos></gml:Point></caaml:pointLocation></caaml:locRef><caaml:snowProfileResultsOf><caaml:SnowProfileMeasurements dir="top down"><caaml:profileDepth uom="cm">80.0</caaml:profileDepth><caaml:weatherCond><caaml:airTempPres uom="degC">3.9</caaml:airTempPres></caaml:weatherCond><caaml:snowPackCond><caaml:hS><caaml:Components><caaml:height uom="cm">80.0</caaml:height></caaml:Components></caaml:hS></caaml:snowPackCond><caaml:stratProfile><caaml:Layer><caaml:depthTop uom="cm">0.0</caaml:depthTop><caaml:thickness uom="cm">4.0</caaml:thickness><caaml:wetness uom="">D</caaml:wetness><caaml:grainFormPrimary>DF</caaml:grainFormPrimary><caaml:grainFormSecondary>RG</caaml:grainFormSecondary><caaml:grainSize uom="mm"><caaml:Components><caaml:avg>0.8</caaml:avg><caaml:avgMax>1.2</caaml:avgMax></caaml:Components></caaml:grainSize><caaml:hardness uom="">F</caaml:hardness></caaml:Layer><caaml:Layer><caam