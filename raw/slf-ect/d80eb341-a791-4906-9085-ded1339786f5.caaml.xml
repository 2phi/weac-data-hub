<caaml:SnowProfile xmlns:caaml="http://caaml.org/Schemas/SnowProfileIACS/v6.0.3" xmlns:gml="http://www.opengis.net/gml" xmlns:slf="http://www.slf.ch/snowprofile/1.0" gml:id="d80eb341-a791-4906-9085-ded1339786f5"><caaml:metaData><caaml:customData><slf:profiletext-list><slf:profiletext key="TEXT_BLOCK_DEFAULT"><slf:text>Neige vent&#233;e par la bise en d&#233;but de matin&#233;e entre 2200 m et 2600 m, sur l'ar&#234;te de mont&#233;e aux Grandes Ottanes.
Neige poudreuse en matin&#233;e sur toutes les pentes au-dessus de 2600 m. Neige transform&#233;e sur les pentes fortement ensoleill&#233;e &#224; la mi-journ&#233;e sous 2600 m.
Plusieurs petites purges dans les pentes raides au nord avec le transport de neige par la bise matinale.
Beaucoup de d&#233;pose h&#233;li sur le glacier du Trient, condition tr&#232;s bonne.</slf:text></slf:profiletext></slf:profiletext-list></caaml:customData></caaml:metaData><caaml:timeRef><caaml:recordTime><caaml:TimeInstant><caaml:timePosition>2025-03-18T14:00:36+01:00</caaml:timePosition></caaml:TimeInstant></caaml:recordTime><caaml:dateTimeReport>2025-03-18T17:22:55.118443+01:00</caaml:dateTimeReport><caaml:dateTimeLastEdit>2025-03-18T17:22:55.118443+01:00</caaml:dateTimeLastEdit></caaml:timeRef><caaml:srcRef/><caaml:locRef><caaml:name>Pointe des Berons / Chaux des Grands /Trient</caaml:name><caaml:validElevation><caaml:ElevationPosition uom="m"><caaml:position>2717</caaml:position></caaml:ElevationPosition></caaml:validElevation><caaml:validAspect><caaml:AspectPosition><caaml:position>NE</caaml:position></caaml:AspectPosition></caaml:validAspect><caaml:validSlopeAngle><caaml:SlopeAnglePosition uom="deg"><caaml:position>35</caaml:position></caaml:SlopeAnglePosition></caaml:validSlopeAngle><caaml:pointLocation><gml:Point id="pointID" srsName="urn:ogc:def:crs:OGC:1.3:CRS84" srsDimension="2"><gml:pos>6.984494 46.012749</gml:pos></gml:Point></caaml:pointLocation></caaml:locRef><caaml:snowProfileResultsOf><caaml:SnowProfileMeasurements dir="top down"><caaml:profileDepth uom="cm">174.0</caaml:profileDepth><caaml:weatherCond><caaml:airTempPres uom="degC">-1.5</caaml:airTempPres></caaml:weatherCond><caaml:snowPackCond><caaml:hS><caaml:Components><caaml:height uom="cm">174.0</caaml:height></caaml:Components></caaml:hS></caaml:snowPackCond><caaml:stratProfile><caaml:Layer><caaml:depthTop uom="cm">0.0</caaml:depthTop><caaml:thickness uom="cm">1.0</caaml:thickness><caaml:wetness uom="">D</caaml:wetness><caaml:grainFormPrimary>SH</caaml:grainFormPrimary><caaml:grainFormSecondary>PP</caaml:grainFormSecondary><caaml:grainSize uom="mm"><caaml:Components><caaml:avg>1.0</caaml:avg><caaml:avgMax>4.0</caaml:avgMax></caaml:Components></caaml:grainSize><caaml:hardness uom="">F</caaml