<caaml:SnowProfile xmlns:caaml="http://caaml.org/Schemas/SnowProfileIACS/v6.0.3" xmlns:gml="http://www.opengis.net/gml" xmlns:slf="http://www.slf.ch/snowprofile/1.0" gml:id="bddd38d4-a2ce-454a-9869-8d92e0b61bd3"><caaml:metaData><caaml:customData><slf:profiletext-list><slf:profiletext key="TEXT_BLOCK_DEFAULT"><slf:text>Referenzprofil erstes drittel der dritten Profillinie.

Schneedecke komplett isotherm, nur noch Schmelzformen und Eislamellen vorhanden. Schnee durchwegs pappig, in tieferen Schichten ist fl&#252;ssiges Wasser sichtbar.

Oberfl&#228;chennah (88-87cm) sehr markante und por&#246;se Schicht aus gro&#223;en Hagelk&#246;rnern, hier jedoch kein Bruch beim ECT

Tiefere Schichten schwer auseinander zu halten

Bew&#246;lkung 5/8</slf:text></slf:profiletext></slf:profiletext-list></caaml:customData></caaml:metaData><caaml:timeRef><caaml:recordTime><caaml:TimeInstant><caaml:timePosition>2025-05-15T12:23:48+02:00</caaml:timePosition></caaml:TimeInstant></caaml:recordTime><caaml:dateTimeReport>2025-05-15T13:05:14.367503+02:00</caaml:dateTimeReport><caaml:dateTimeLastEdit>2025-05-15T13:05:14.367503+02:00</caaml:dateTimeLastEdit></caaml:timeRef><caaml:srcRef/><caaml:locRef><caaml:name>Weissfluhjoch 5WJ</caaml:name><caaml:validElevation><caaml:ElevationPosition uom="m"><caaml:position>2536</caaml:position></caaml:ElevationPosition></caaml:validElevation><caaml:validSlopeAngle><caaml:SlopeAnglePosition uom="deg"><caaml:position>0</caaml:position></caaml:SlopeAnglePosition></caaml:validSlopeAngle><caaml:pointLocation><gml:Point id="pointID" srsName="urn:ogc:def:crs:OGC:1.3:CRS84" srsDimension="2"><gml:pos>9.80924 46.82963</gml:pos></gml:Point></caaml:pointLocation></caaml:locRef><caaml:snowProfileResultsOf><caaml:SnowProfileMeasurements dir="top down"><caaml:profileDepth uom="cm">90.0</caaml:profileDepth><caaml:weatherCond><caaml:airTempPres uom="degC">0.3</caaml:airTempPres></caaml:weatherCond><caaml:snowPackCond><caaml:hS><caaml:Components><caaml:height uom="cm">90.0</caaml:height></caaml:Components></caaml:hS></caaml:snowPackCond><caaml:stratProfile><caaml:Layer><caaml:depthTop uom="cm">0.0</caaml:depthTop><caaml:thickness uom="cm">2.0</caaml:thickness><caaml:wetness uom="">M-W</caaml:wetness><caaml:grainFormPrimary>MF</caaml:grainFormPrimary><caaml:grainSize uom="mm"><caaml:Components><caaml:avg>0.5</caaml:avg><caaml:avgMax>1.0</caaml:avgMax></caaml:Components></caaml:grainSize><caaml:hardness uom="">4F</caaml:hardness></caaml:Layer><caaml:Layer><caaml:depthTop uom="cm">2.0</caaml:depthTop><caaml:thickness uom="cm">1.0</caaml:thickness><caaml:wetness uom="">M</caaml:wetness><caaml:grainFormPrimary>PPgp</caaml:grainFormPrimary><caaml:grainFormSecondary>MF</caaml:grainFormSecond